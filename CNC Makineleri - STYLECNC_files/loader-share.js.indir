async function loadHeader(){const stylecncresponse=await fetch("/assets/header.html",{priority:"low"});const stylecnctext=await stylecncresponse.text();document.getElementById('header').insertAdjacentHTML('beforeend',stylecnctext)}window.addEventListener("load",function(){if(window.innerWidth>768){loadHeader();let html = document.getElementById("main-menu").innerHTML;document.getElementById("main-menu-sticky").innerHTML = html;let btnlist = document.getElementById("btn-list").innerHTML;document.getElementById("stylecnc-btn-list").innerHTML = btnlist;let logolist = document.getElementById("logo-list").innerHTML;document.getElementById("stylecnc-logo-list").innerHTML = logolist;}});async function loadFooter(){const stylecncresponse=await fetch("/assets/footer.html",{priority:"low"});const stylecnctext=await stylecncresponse.text();document.getElementById('footer').insertAdjacentHTML('beforeend',stylecnctext)}loadFooter();async function loadShares(){const stylecncresponse=await fetch("/assets/share.html",{priority:"low"});const stylecnctext=await stylecncresponse.text();document.getElementById('shares').insertAdjacentHTML('beforeend',stylecnctext)}loadShares();